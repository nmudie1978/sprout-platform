# Database
# Get from: Supabase, Neon, Railway, or local PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/youth_platform"
DIRECT_URL="postgresql://user:password@localhost:5432/youth_platform" # For migrations (optional)

# NextAuth
# Production URL (e.g., https://yourapp.com)
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# Email (for magic link authentication)
# Options: Gmail, SendGrid, AWS SES, etc.
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="noreply@youthplatform.no"

# OpenAI (Optional - for AI Assistant feature)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# VIPPS OAuth (Recommended for Norwegian users)
# Get from: https://portal.vippsmobilepay.com (requires BankID + business account)
# Docs: https://developer.vippsmobilepay.com/docs/APIs/login-api/
# Provides verified identity: name, email, phone, birthdate
VIPPS_CLIENT_ID="your-vipps-client-id"
VIPPS_CLIENT_SECRET="your-vipps-client-secret"
NEXT_PUBLIC_VIPPS_ENABLED="false"  # Set to "true" when credentials are configured

# Rate Limiting (REQUIRED in production)
# lib/rate-limit.ts hard-fails on boot in production when these are
# missing — in-memory rate limits don't survive Vercel's multi-instance
# runtime, so signup/report/AI-quota rate limits become bypassable.
# Set RATE_LIMIT_ALLOW_IN_MEMORY=true only for one-off test deploys.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# RATE_LIMIT_ALLOW_IN_MEMORY="true"   # Escape hatch — never use on prod

# Sentry — Error monitoring
# Get a DSN from https://sentry.io (free tier is fine to start).
# Without these, the app still runs; errors just aren't captured.
# - NEXT_PUBLIC_SENTRY_DSN: browser runtime (client errors, React error
#   boundaries, replays). Must start with NEXT_PUBLIC_ so Next.js inlines
#   it into the client bundle.
# - SENTRY_DSN: server runtime (API routes, Server Components, Server
#   Actions). Can be the same DSN as the public one.
# - SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT: only needed if you
#   want source-map upload at build time. Safe to leave unset in dev.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Cron secret — bearer token the Vercel Cron scheduler sends on calls
# to /api/cron/*. Required in production; the purge endpoint rejects
# unauthenticated requests.
CRON_SECRET=""

# School mode — allowlist of additional domains accepted for TEACHER
# signup, comma-separated. The static list already covers *.skole.no,
# *.vgs.no, *.fylkeskommune.no, *.kommune.no, .edu, .ac.uk, .sch.uk.
# SCHOOL_EMAIL_ALLOWLIST="example-school.com,another.org"

# Small jobs feature flag — when "true", re-enables the paused small-
# jobs marketplace surface (sidebar sections, dashboard widget, /jobs
# routes). Code and DB are preserved when off.
# NEXT_PUBLIC_SMALL_JOBS_ENABLED="true"

# Admin Access
# Email addresses with admin access to platform analytics
# Set this to your email to access /admin/analytics
ADMIN_EMAIL="your-email@example.com"
NEXT_PUBLIC_ADMIN_EMAIL="your-email@example.com"

# Admin session (separate from NextAuth — used by the /admin/* JWT
# cookie flow). Username + bcrypt hash of the password + signing secret.
# Generate the hash with: node -e "require('bcryptjs').hash('YOUR_PW',10).then(console.log)"
# Generate the secret with: openssl rand -base64 32
ADMIN_USERNAME=""
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET=""

# Environment
NODE_ENV="development"

# Demo Data Seeding (Development Only)
# Used by: npm run db:seed-demo
ENABLE_DEMO_DATA="false"     # Set to "true" to enable demo data seeding
DEMO_DATA_RESET="false"      # Set to "true" to delete existing demo data before reseeding

# Motion Trial (Experimental)
# Enables premium animation features in My Journey page
# Set to "true" to enable the motion trial feature flag
NEXT_PUBLIC_MOTION_TRIAL="false"
