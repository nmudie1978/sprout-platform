// PathSnapshot - Point-in-time career direction report
model PathSnapshot {
  id          String   @id @default(cuid())
  userId      String
  headline    String // "Your current direction" - 1 line summary
  direction   String[] // 1-3 recommended roles
  nextActions Json // Array of 3-7 actionable steps
  confidence  String // "low" | "medium" | "high"
  rationale   String?  @db.Text // Short explanation grounded in user activity
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
}

// ============================================
// PROFESSIONAL INSIGHTS (Phase 2 Feature)
// One-way career insights from real professionals
// ============================================

// Media type for professional insights
enum ProfessionalInsightMediaType {
  VIDEO
  AUDIO
  TEXT
}

// ProfessionalInsight - Real career insights from professionals
// Phase 2 feature - placeholder in MVP, curated content later
model ProfessionalInsight {
  id          String                       @id @default(cuid())
  careerTag   String // Career/role tag (e.g., "software-engineer", "lawyer")
  title       String // Insight title
  mediaType   ProfessionalInsightMediaType // Type of media
  mediaUrl    String? // URL to video/audio (nullable for text-only)
  transcript  String?                      @db.Text // Text content or video/audio transcript
  authorName  String? // Optional: professional's name (if consented)
  authorRole  String? // Job title/role
  authorYears Int? // Years of experience
  isPublished Boolean                      @default(false) // Admin approval required
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([careerTag])
  @@index([isPublished])
  @@index([createdAt])
}

// ============================================
// AI CHAT MEMORY (Persistent Conversation History)
// ============================================

model AiChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String // "user" or "assistant"
  content   String   @db.Text
  intent    String? // Optional: store classified intent
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// One persisted turn of a Career Twin conversation. Scoped per user AND per
/// career so "Doctor future self" and "Software dev future self" are distinct
/// threads. Youth conversation data — always query by userId; cascade-delete.
model CareerTwinMessage {
  id        String   @id @default(cuid())
  userId    String
  careerId  String // resolved catalog id, or a title hint for off-catalog careers
  role      String // "user" | "assistant"
  content   String   @db.Text
  mode      String? // career-twin mode id active for this turn (e.g. "hard_truths")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, careerId, createdAt])
}

// ============================================
// INDUSTRY INSIGHT VIDEOS (Content Freshness System)
// ============================================

enum IndustryInsightVideoStatus {
  ACTIVE // Currently displayed to users
  REFRESH_DUE // Content is stale, needs regeneration
  REGENERATING // Being regenerated with new content
  ARCHIVED // Previous version, kept for history
}

model IndustryInsightVideo {
  id           String  @id @default(uuid())
  industry     String // e.g., "tech", "health", "green", "creative"
  role         String? // Optional specialization (e.g., "Developer", "Nurse")
  title        String // Video title
  description  String? @db.Text // Video description
  videoUrl     String // YouTube URL or video ID
  thumbnailUrl String? // Custom thumbnail (optional)
  duration     String? // e.g., "12:34"
  channel      String? // Source channel name
  topic        String? // Topic tag (e.g., "AI Impact", "Skills")

  // Content generation tracking
  generatedBy   String    @default("manual") // "AI" or "manual"
  generatedAt   DateTime  @default(now())
  refreshDueAt  DateTime // generatedAt + 90 days
  lastCheckedAt DateTime? // When freshness was last verified

  // Status and versioning
  status            IndustryInsightVideoStatus @default(ACTIVE)
  version           Int                        @default(1)
  previousVersionId String? // Reference to archived version

  // AI regeneration metadata
  aiPrompt String? @db.Text // Prompt used for AI generation
  aiModel  String? // Model used (e.g., "gpt-4")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([industry, role, status], name: "unique_active_video")
  @@index([industry])
  @@index([status])
  @@index([refreshDueAt])
  @@index([generatedAt])
}

// ============================================
// INDUSTRY INSIGHTS MODULES (90-Day Verify & Refresh System)
// ============================================
// Modular content system for Industry Insights page.
// Each module is independently verified and refreshed based on cadence.
// System-generated content must be in English only.

enum InsightsModuleStatus {
  ACTIVE // Currently displayed, within verification window
  VERIFY_DUE // Verification window exceeded, needs checking
  REGENERATING // Currently being refreshed with new data
}

model IndustryInsightsModule {
  id          String  @id @default(uuid())
  key         String  @unique // e.g., "top_industries", "skills_trends"
  title       String // Display title
  description String? // Optional description

  // Content storage (English-only for renderedSummary)
  contentJson     Json // Structured data (arrays, objects)
  renderedSummary String? @db.Text // English-only summary text for UI
  sourceMeta      Json? // Provider info: {provider, fetchedAt, urls}

  // Verification tracking
  lastGeneratedAt    DateTime             @default(now())
  lastVerifiedAt     DateTime             @default(now())
  refreshCadenceDays Int                  @default(90) // Default 90 days
  status             InsightsModuleStatus @default(ACTIVE)

  // Change detection thresholds (per-module)
  // e.g., {"salaryPct": 10, "rankShift": 2, "listDiffPct": 20}
  changeThreshold Json @default("{}")

  // Versioning
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([lastVerifiedAt])
  @@index([key])
}

// ============================================
// VERIFIED LEARNING RESOURCES
// ============================================
// Accuracy-first learning recommendations system.
// Only includes courses/certifications that have been verified as real and current.
// See /docs/verified-learning.md for full documentation.

enum LearningProviderType {
  UNIVERSITY // Universities and colleges
  PUBLIC_BODY // Government / public education bodies
  INDUSTRY_CERT // Industry certification bodies (CompTIA, AWS, etc.)
  ONLINE_PLATFORM // Major online learning platforms (Coursera, etc.)
}

enum LearningDeliveryMode {
  ONLINE // Fully online / remote
  IN_PERSON // Requires physical attendance
  HYBRID // Mix of online and in-person
}

enum LearningRegionScope {
  LOCAL // Country-specific (e.g., Norway only)
  REGIONAL // Regional (e.g., Nordics, EU)
  INTERNATIONAL // Globally accessible
}

enum LearningCertificationType {
  PROFESSIONAL_CERT // Industry-recognized certification
  COURSE_COMPLETION // Certificate of completion
  DIGITAL_BADGE // Micro-credential / badge
  ACADEMIC_CREDIT // University credit / qualification
  NONE // No certificate offered
}

enum LearningPrerequisiteLevel {
  NONE // No prerequisites
  BASIC // Basic computer/reading skills
  INTERMEDIATE // Some prior knowledge required
  ADVANCED // Significant prior experience needed
}

enum LearningResourceStatus {
  VERIFIED // Actively verified as available
  PENDING_VERIFICATION // Awaiting verification
  VERIFICATION_FAILED // Could not verify - do not display
  ARCHIVED // Previously valid, now discontinued
}

// Verified Learning Resource - ACCURACY FIRST
// Only courses that have been verified as real and currently available
model VerifiedLearningResource {
  id String @id @default(uuid())

  // Core identification
  title        String // Official course/certification name
  provider     String // e.g., "Coursera", "Google", "NAV"
  providerType LearningProviderType

  // Delivery & accessibility
  deliveryMode  LearningDeliveryMode
  regionScope   LearningRegionScope
  regionDetails String? // e.g., "Norway", "EU/EEA", "Global"
  language      String               @default("en") // Primary language

  // Duration & commitment
  duration            String // e.g., "6 weeks", "3 months", "Self-paced"
  timeCommitmentHours Int? // Hours per week if known

  // Cost
  cost                  String // "Free", "Paid", or specific amount
  costAmount            Decimal? @db.Decimal(10, 2) // Numeric cost if known
  costCurrency          String? // e.g., "NOK", "USD", "EUR"
  financialAidAvailable Boolean  @default(false)

  // Certification & recognition
  certificationType LearningCertificationType
  recognisedBy      String[] // Who recognizes this cert
  industryValue     String? // Brief note on industry recognition

  // Age & prerequisites
  minimumAge          Int? // Minimum age if specified
  ageSuitability      String // e.g., "16+", "18+", "All ages"
  prerequisiteLevel   LearningPrerequisiteLevel
  prerequisiteDetails String? // Specific prereqs if any

  // Career relevance
  relevantCareers String[] // Career paths this supports
  relevantSkills  String[] // Skills taught/developed

  // Official URL - MUST be real and verified
  officialUrl String // Direct link to course page

  // Verification tracking (critical for accuracy)
  status             LearningResourceStatus @default(PENDING_VERIFICATION)
  lastVerifiedAt     DateTime? // When we last confirmed it exists
  verificationNotes  String? // Notes from verification
  verificationSource String? // How we verified (manual, API, etc.)

  // Metadata
  description String?  @db.Text // Brief description
  highlights  String[] // Key selling points

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userProgress UserLearningProgress[]

  @@index([status])
  @@index([provider])
  @@index([relevantCareers])
  @@index([regionScope])
  @@index([lastVerifiedAt])
}

// User's saved/tracked learning resources
model UserLearningProgress {
  id         String @id @default(uuid())
  userId     String
  resourceId String

  // Progress tracking
  status      String    @default("saved") // saved, in_progress, completed
  startedAt   DateTime?
  completedAt DateTime?

  // User notes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource VerifiedLearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
}

// ============================================
// PARENT/GUARDIAN VISIBILITY LAYER
// ============================================

// ============================================
// AGE ELIGIBILITY POLICY SYSTEM
// Versioned, auditable age requirements for jobs
// SAFETY CRITICAL - see /docs/age-eligibility-policy.md
// ============================================

// AgePolicy - Versioned policy storage (single source of truth)
// There must always be exactly one ACTIVE policy
// Policy contains minimum age requirements per risk category
model AgePolicy {
  id      String          @id @default(uuid())
  version Int             @unique // Monotonically increasing version number
  status  AgePolicyStatus @default(ACTIVE)

  // Policy rules as JSON for flexibility
  // Example: { "LOW_RISK": { "minAge": 15 }, "MEDIUM_RISK": { "minAge": 16 }, "HIGH_RISK": { "minAge": 18 } }
  policyJson Json

  // Optional description of policy changes
  description String? @db.Text

  // Who created this policy version (admin only)
  createdById String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime? // When policy was archived (superseded)

  @@index([status])
  @@index([version])
  @@index([createdAt])
}

// AgeEligibilityAuditLog - Tracks all age-related eligibility decisions
// CRITICAL: Used for compliance, safety audits, and debugging
// Never delete these records
model AgeEligibilityAuditLog {
  id String @id @default(uuid())

  // Who and what
  workerId   String? // Youth worker attempting to apply (null if job publish)
  jobId      String // Job being applied to or published
  employerId String? // Employer who posted the job

  // What happened
  action AgeEligibilityAction // APPLY_BLOCKED, APPLY_ALLOWED, JOB_PUBLISH_ADJUSTED
  reason String               @db.Text // Human-readable explanation

  // Age details (NEVER store actual DOB in audit logs)
  requiredMinAge Int // The minimum age required
  userAge        Int? // Worker's age at time of check (null for job publish)
  userAgeBracket String? // AGE_15, AGE_16, etc.

  // Policy version for traceability
  policyVersion Int

  // Additional context
  metadata  Json? // Extra context (e.g., employer's requested age)
  ipAddress String? // For security auditing

  createdAt DateTime @default(now())

  @@index([workerId])
  @@index([employerId])
  @@index([action])
  @@index([policyVersion])
  @@index([createdAt])
  @@index([jobId])
  @@index([workerId, jobId]) // For checking if a specific apply was logged
}

// ============================================
// INTERVIEW PREP SYSTEM
// ============================================

// Interview questions - can be seeded or generated
model InterviewQuestion {
  id           String   @id @default(cuid())
  category     String // General, Tech, Healthcare, Green, Creative
  difficulty   String // Easy, Medium, Hard
  questionText String   @db.Text
  tip          String?  @db.Text
  answerHint   String?  @db.Text
  tags         String[] // For search/filtering
  isGenerated  Boolean  @default(false) // AI-generated vs seeded
  createdAt    DateTime @default(now())

  userStates        UserQuestionState[]
  generatedSetItems GeneratedSetQuestion[]

  @@index([category])
  @@index([difficulty])
  @@index([isGenerated])
}

// Generated question sets - tracks sets created by users
model GeneratedQuestionSet {
  id            String   @id @default(cuid())
  userId        String
  roleTarget    String? // e.g., "Software Engineer"
  category      String // Category filter used
  difficultyMix Json // { easy: 2, medium: 3, hard: 1 }
  focusAreas    String[] // Optional focus areas
  generatorType String   @default("MOCK") // MOCK or AI
  createdAt     DateTime @default(now())

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions GeneratedSetQuestion[]

  @@index([userId])
  @@index([createdAt])
}

// Junction table for generated sets and questions
model GeneratedSetQuestion {
  id         String @id @default(cuid())
  setId      String
  questionId String
  sortOrder  Int    @default(0)

  set      GeneratedQuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  question InterviewQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([setId, questionId])
  @@index([setId])
  @@index([questionId])
}

// User state for each question - saved, practiced, notes
model UserQuestionState {
  id              String    @id @default(cuid())
  userId          String
  questionId      String
  saved           Boolean   @default(false)
  practicedCount  Int       @default(0)
  lastPracticedAt DateTime?
  confidence      Int? // 1-5 rating
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
  @@index([saved])
  @@index([lastPracticedAt])
}

// ============================================
// CAREER EVENTS CALENDAR
// ============================================

enum CareerEventType {
  JOBFAIR
  WEBINAR
  MEETUP
  WORKSHOP
  CONFERENCE
}

enum LocationMode {
  IN_PERSON
  ONLINE
  HYBRID
}

model CareerEvent {
  id          String          @id @default(cuid())
  title       String
  type        CareerEventType
  description String          @db.Text
  organizer   String

  // Date and time
  startDate DateTime
  endDate   DateTime? // Optional for single-day events
  time      String // Display time range e.g., "09:00 - 17:00"

  // Location
  locationMode LocationMode
  city         String? // City for in-person events
  region       String? // Region/county
  country      String? // Country
  venue        String? // Specific venue name/address
  lat          Float? // Latitude for distance calculations
  lng          Float? // Longitude for distance calculations
  onlineUrl    String? // URL for online events

  // Registration
  registrationUrl String
  spots           Int? // Optional capacity limit

  // Youth targeting
  isYouthFocused Boolean  @default(false) // Explicitly targets 15-23 age group
  industryTypes  String[] // e.g., ["tech", "green", "health", "creative"]

  // Verification - events must be verified before display
  // Admin/curator must confirm the event exists and URL is valid
  isVerified        Boolean   @default(false) // Only verified events are shown
  verifiedAt        DateTime? // When the event was last verified
  verificationNotes String?   @db.Text // Notes from verification (e.g., "URL confirmed working")

  // Status
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([locationMode])
  @@index([isYouthFocused])
  @@index([isActive])
  @@index([isVerified])
  @@index([city])
  @@index([country])
  @@index([isActive, isVerified, startDate]) // Compound: main event listing query
  @@index([isYouthFocused, startDate]) // Compound: sorted event display
}

// ============================================
// IN-APP FEEDBACK (BETA)
// ============================================

enum FeedbackKind {
  CONFUSED
  PROBLEM
  IDEA
  PRAISE
}

enum FeedbackArea {
  JOURNEY
  CAREER_RADAR
  EXPLORE_CAREERS
  LIBRARY
  CAREER_TWIN
  OTHER
}

// Role of feedback submitter
enum FeedbackRole {
  TEEN_16_20
  PARENT_GUARDIAN
  ADULT_OTHER
}

// Clarity topics that users can select
// Stored as String[] in clarityTopics field
// Valid values: PRIMARY_VS_SECONDARY_GOAL, REAL_LIFE_WORK, SMALL_JOBS, NEXT_STEPS, NONE

// Feedback submission - usability signals from beta users
// NO PII: no name, email, DOB, phone stored
model Feedback {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Optional link to user (null if submitted anonymously)
  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Typed feedback (current model)
  kind    FeedbackKind?
  area    FeedbackArea?
  message String?       @db.VarChar(1000)

  // Who is giving feedback (optional)
  role FeedbackRole?

  // Legacy Likert pilot fields (no longer collected; kept for old rows)
  q1 Int?
  q2 Int?
  q3 Int?
  q4 Int?
  q5 Int?

  // Legacy free-text + clarity topics (kept for old rows)
  confusingText String?  @db.VarChar(500)
  clarityTopics String[]

  // Optional metadata
  source     String? @db.VarChar(50)
  userAgent  String? @db.VarChar(200)
  appVersion String? @db.VarChar(20)

  @@index([createdAt])
  @@index([role])
  @@index([kind])
  @@index([area])
}

// ============================================
// CAREER CLIPS
// Curated, verified video clips for career exploration
// Non-addictive, small collection per career category
// ============================================

enum CareerClipPlatform {
  TIKTOK
  YOUTUBE_SHORTS
}

enum CareerClipVerifiedStatus {
  PENDING // Not yet validated
  VALID // URL verified and working
  INVALID // URL broken or removed
}

model CareerClip {
  id           String             @id @default(cuid())
  careerSlug   String             @db.VarChar(100) // e.g., "doctor", "electrician"
  categorySlug String             @db.VarChar(100) // e.g., "healthcare", "technology"
  title        String             @db.VarChar(200)
  platform     CareerClipPlatform
  url          String             @db.VarChar(500)
  thumbnailUrl String?            @db.VarChar(500)
  durationSecs Int? // Duration in seconds, if known

  // Verification status - ONLY valid clips are displayed
  verifiedStatus  CareerClipVerifiedStatus @default(PENDING)
  lastCheckedAt   DateTime?
  checkFailReason String?                  @db.VarChar(500)

  // Metadata
  sourceLabel  String @default("") @db.VarChar(100) // e.g., "TikTok (verified link)"
  displayOrder Int    @default(0) // For manual ordering within category

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([careerSlug])
  @@index([categorySlug])
  @@index([verifiedStatus])
  @@index([displayOrder])
}

// ============================================
// MY JOURNEY - SAVED ITEMS (My Library)
// Users can save articles, videos, podcasts, shorts for later
// ============================================

enum SavedItemType {
  ARTICLE
  VIDEO
  PODCAST
  SHORT // TikTok, Reels, YouTube Shorts
}

model SavedItem {
  id        String        @id @default(cuid())
  profileId String
  type      SavedItemType
  title     String        @db.VarChar(300)
  url       String        @db.VarChar(1000)
  source    String?       @db.VarChar(100) // e.g., "YouTube", "Medium", "TikTok"
  tags      String[]      @default([]) // Free-form tags

  // Career/role context tagging
  careerPathId String? // Links to SavedIndustry or career slug
  roleId       String? // Links to a specific role deep dive

  // Metadata
  thumbnail   String?   @db.VarChar(500)
  description String?   @db.Text
  savedAt     DateTime  @default(now())
  deletedAt   DateTime? // null = active, set = soft-deleted

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([type])
  @@index([savedAt])
  @@index([careerPathId])
}

/// A career the youth bookmarked (the heart on a career card). One row per
/// profile+career. Mirrors the former SavedCuriosity localStorage shape so the
/// dashboard's "Saved Careers" survives a device/browser change.
model SavedCareer {
  id          String   @id @default(cuid())
  profileId   String
  careerId    String // slug or catalog id
  careerTitle String
  careerEmoji String?
  note        String?  @db.Text
  savedAt     DateTime @default(now())

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, careerId])
  @@index([profileId, savedAt])
}

/// The "My Journey" reflection notebook: one row per profile+career holding
/// the free-text Discover / Understand / Clarity reflections. Mirrors the
/// `endeavrly-journey-reflections` localStorage record so reflections survive
/// a device/browser change. Distinct from the prompt-based JourneyReflection.
model JourneyNotebook {
  id         String   @id @default(cuid())
  profileId  String
  careerSlug String
  discover   String?  @db.Text
  understand String?  @db.Text
  clarity    String?  @db.Text
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, careerSlug])
  @@index([profileId, updatedAt])
}

// ============================================
// MY JOURNEY - REFLECTIONS
// Micro-reflections after major actions
// ============================================

enum ReflectionContextType {
  ALIGNED_ACTION
  ROLE_DEEP_DIVE
  INDUSTRY_INSIGHTS
  SHADOW_COMPLETED
  CAREER_DISCOVERY
  PLAN_BUILD
  STRENGTHS_REFLECTION
}

model JourneyReflection {
  id          String                @id @default(cuid())
  profileId   String
  contextType ReflectionContextType
  contextId   String? // ID of the related item (job, shadow, etc.)

  // The reflection itself
  prompt   String  @db.VarChar(500) // The question asked
  response String? @db.Text // User's response (optional - they can skip)
  skipped  Boolean @default(false) // Did user skip this reflection?

  createdAt DateTime @default(now())

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([contextType])
  @@index([createdAt])
}

// ============================================
// MY JOURNEY - TIMELINE EVENTS
// Unified timeline for significant journey moments
// ============================================

enum TimelineEventType {
  PROFILE_CREATED
  STRENGTHS_CONFIRMED
  CAREER_EXPLORED
  ROLE_DEEP_DIVE_COMPLETED
  PRIMARY_GOAL_SET
  INDUSTRY_OUTLOOK_REVIEWED
  REQUIREMENTS_REVIEWED
  PLAN_CREATED
  PLAN_UPDATED
  SHADOW_REQUESTED
  SHADOW_APPROVED
  SHADOW_DECLINED
  SHADOW_COMPLETED
  SHADOW_SKIPPED
  ALIGNED_ACTION_COMPLETED
  ACTION_REFLECTION_SUBMITTED
  EXTERNAL_FEEDBACK_RECEIVED
  ITEM_SAVED
  REFLECTION_RECORDED
}

model TimelineEvent {
  id        String            @id @default(cuid())
  userId    String
  type      TimelineEventType
  metadata  Json? // Additional context (title, details, etc.)
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// MY JOURNEY - PERSONAL NOTES
// Free-form notes for users to capture thoughts
// ============================================

model JourneyNote {
  id        String    @id @default(cuid())
  profileId String
  title     String?   @db.VarChar(200) // Optional title
  content   String    @db.Text // The note content
  color     String?   @db.VarChar(20) // Optional color tag (yellow, blue, green, etc.)
  pinned    Boolean   @default(false) // Pin important notes to top
  groupName String?   @db.VarChar(100) // Optional named group
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // null = active, set = soft-deleted

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([profileId, groupName])
  @@index([createdAt])
  @@index([pinned])
}

model TraitObservation {
  id          String    @id @default(cuid())
  profileId   String
  traitId     String    @db.VarChar(50)
  observation String    @db.VarChar(20) // "noticed" | "unsure" | "not_me"
  contextType String?   @db.VarChar(50)
  contextId   String?   @db.VarChar(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // null = active, set = soft-deleted

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, traitId])
  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([traitId])
}

// ============================================
// MY JOURNEY - SNAPSHOTS (Recovery)
// Full journey backups for undo/import safety
// ============================================

model JourneySnapshot {
  id        String   @id @default(cuid())
  profileId String
  trigger   String   @db.VarChar(50) // "manual" | "pre_import" | "pre_bulk_delete" | "pre_restore"
  label     String?  @db.VarChar(200)
  data      Json // Full journey export envelope
  createdAt DateTime @default(now())

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([createdAt])
}

model ContentInteraction {
  id              String   @id @default(cuid())
  profileId       String
  contentUrl      String   @db.VarChar(1000)
  interactionType String   @db.VarChar(20) // "watched"
  createdAt       DateTime @default(now())

  profile YouthProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentUrl, interactionType])
  @@index([profileId])
}

// ============================================
// TRANSLATION CACHE
// ============================================

model TranslationCache {
  id           String   @id @default(cuid())
  contentHash  String // SHA-256 of source text
  sourceLocale String   @db.VarChar(5)
  targetLocale String   @db.VarChar(5)
  sourceText   String   @db.Text
  translated   String   @db.Text
  contentType  String   @db.VarChar(50)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime

  @@unique([contentHash, targetLocale])
  @@index([contentHash, targetLocale])
  @@index([expiresAt])
}

// ============================================
// GOAL-SCOPED JOURNEY DATA
// ============================================
// Stores all journey progress and data per goal per user.
// When a user switches goals, their data is preserved here
// and can be loaded back when they return to that goal.

model JourneyGoalData {
  id        String @id @default(cuid())
  userId    String
  goalId    String // Slugified goal title (e.g., "physiotherapist-fysioterapeut")
  goalTitle String // Human-readable goal title

  // Journey state for this goal
  journeyState          String   @default("REFLECT_ON_STRENGTHS")
  journeyCompletedSteps String[] @default([])
  journeySkippedSteps   Json?

  // Goal-specific summary (role reality, path, actions, reflections, etc.)
  journeySummary Json?

  // Roadmap card annotations (status, notes, resource, confidence per card)
  roadmapCardData Json? // { [itemId]: { status, notes, resourceLink, confidence } }

  // Cached generated roadmap
  generatedTimeline Json?

  // Status
  isActive  Boolean  @default(false) // Is this the currently active goal?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId])
  @@index([userId])
  @@index([userId, isActive])
}

// ============================================
// CAREER INTEREST — the ★1–5 self-rating a young
// person gives a career ("possible future"). Server-
// authoritative source for the My Library "Exploring"
// tab (ranked, categorised). Keyed by careerId (the
// slugified career id) to mirror the device-local
// store it supersedes. Explicit self-rating only —
// no behavioural tracking. See docs spec
// 2026-06-02-library-exploring-tab-design.md.
// ============================================

model CareerInterest {
  id        String   @id @default(cuid())
  userId    String
  careerId  String // Slugified career id (matches Career.id)
  level     Int // 1–5 (validated at the API layer)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@index([userId])
}

// ============================================
// CAREER STORIES — "From the Field"
// Short video stories from real professionals
// ============================================

model CareerStory {
  id String @id @default(cuid())

  // Video
  videoUrl String // YouTube URL (e.g. https://youtube.com/watch?v=xxx or youtu.be/xxx)
  videoId  String // Extracted YouTube video ID for embedding
  duration String? // e.g. "3:45"

  // Person
  name        String // e.g. "Nicky M."
  jobTitle    String // e.g. "Programme Manager"
  company     String? // e.g. "Telenor" (optional, can be anonymised)
  location    String? // e.g. "Oslo"
  yearsInRole Int? // e.g. 15

  // Tagging — links story to careers
  careerTags String[] // e.g. ["it-project-manager", "programme-manager"]
  industry   String? // e.g. "Telecommunications"

  // Content
  headline  String // e.g. "From junior dev to running a €50M programme"
  takeaways String[] // 2-3 key points, e.g. ["Started as a developer", "Moved into management after 8 years"]

  // Admin
  featured   Boolean @default(false)
  published  Boolean @default(false)
  uploadedBy String? // Admin user ID who uploaded

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([careerTags])
}

// ============================================
// VIDEO CACHE — avoid repeated YouTube API calls
// ============================================

model VideoCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique // e.g. "career-videos:doctor" or "ditl:nurse"
  data      Json // cached API response
  expiresAt DateTime // when to refresh (e.g. 7 days)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cacheKey])
  @@index([expiresAt])
}

// ── Real Career Path Contributions ──────────────────────────────
// Parents, guardians, and professionals contribute their real
// career timelines so young people can see authentic, non-linear
// paths — not just the textbook route. MVP: community-powered,
// moderated, available globally.

enum PathContributionStatus {
  PENDING
  APPROVED
  REJECTED
}

model CareerPathContribution {
  id String @id @default(cuid())

  // Contributor (anonymised in display)
  displayName  String // e.g. "Nicky M." — shown to youth
  currentTitle String // e.g. "Programme Manager"
  country      String // e.g. "Norway", "Hungary" — makes paths globally relevant
  city         String? // optional, e.g. "Oslo"

  // The story — prose prompts the contributor answers
  howIGotHere       String // narrative of the path
  whatIStudied      String // education / training (or none)
  firstSalary       String // free-text so contributors can give context (e.g. "£18k", "minimum wage", "unpaid internship")
  hardestPart       String // hardest part of the journey
  adviceToSeventeen String // what they'd tell their 17-year-old self
  realityOfJob      String // what the job is actually like day-to-day

  // Tagging — links path to careers in the platform
  careerTags String[] // e.g. ["it-project-manager", "programme-manager"]

  // Optional 45s selfie video — stub for now, populated later
  videoUrl String?

  // Moderation
  status     PathContributionStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?

  // Metadata
  submittedByEmail String? // for follow-up only, never displayed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([careerTags])
}

// ============================================
// SCHOOL MODE
// Cohort = a class a teacher has spun up. Students join via code.
// Teacher only ever sees aggregated stats (count, top careers,
// roadmap-generated %). Per-student content is never exposed —
// that's the whole point of structured safeguarding here.
// ============================================

model Cohort {
  id          String    @id @default(cuid())
  // 6-char human-shareable code. Uppercase alphanumeric, confusable
  // chars (0, O, 1, I, L) excluded. Indexed + unique so teachers can
  // quickly look up their own cohort by code and youth can join.
  code        String    @unique
  teacherId   String
  name        String    @db.VarChar(120)
  // Optional career focus — "this class is exploring psychology".
  // Plain-text for MVP; can FK into Career later.
  careerFocus String?   @db.VarChar(80)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft delete so old memberships don't orphan on archive.
  deletedAt   DateTime?

  teacher     User               @relation("TeacherCohorts", fields: [teacherId], references: [id], onDelete: Cascade)
  memberships CohortMembership[]

  @@index([teacherId])
  @@index([code])
  @@index([deletedAt])
  // Compound for the teacher dashboard's "my active cohorts" query —
  // filters by teacherId AND deletedAt IS NULL, ordered by createdAt.
  // Single-column indexes above force a scan + filter; this covers
  // both predicates in one B-tree lookup.
  @@index([teacherId, deletedAt])
}

model CohortMembership {
  id       String   @id @default(cuid())
  cohortId String
  youthId  String
  joinedAt DateTime @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  youth  User   @relation("YouthCohortMemberships", fields: [youthId], references: [id], onDelete: Cascade)

  @@unique([cohortId, youthId])
  @@index([cohortId])
  @@index([youthId])
  // Compound for the youth's "list my classes" query, which filters
  // by youthId and orders by joinedAt DESC.
  @@index([youthId, joinedAt])
}

// ─────────────────────────────────────────────────────────────────────────
// ThemeTally — anonymous aggregate dark/light usage counters.
//
// Privacy-by-design: this stores ONLY two running totals (one row per theme),
// with NO user id, session id, timestamp-per-event, or any other identifier.
// It cannot be tied back to any individual. Incremented at most once per
// browser session, and ONLY for signed-in users (who accepted the Privacy
// Policy at signup) via /api/theme-ping — never on public/marketing pages.
// Used by the admin dashboard to show the dark-vs-light split.
// ─────────────────────────────────────────────────────────────────────────
model ThemeTally {
  theme     String   @id // "dark" | "light"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
