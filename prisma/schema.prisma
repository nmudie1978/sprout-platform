  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
}

// ============================================
// JOB CATEGORIES & TEMPLATES TAXONOMY
// Standardized job categories and templates for quick job posting
// ============================================

// ============================================
// MY PATH - PERSONALIZED JOURNEY HUB
// ============================================

// VaultItem - Portfolio evidence and proof
model VaultItem {
