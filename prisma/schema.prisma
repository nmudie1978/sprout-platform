  @@unique([userId, industryId, stepType, stepId])
  @@index([userId, industryId])
}

// Career Quiz Results
model CareerQuizResult {
  id            String   @id @default(cuid())
  userId        String? // Optional - allow anonymous quizzes
  sessionId     String? // For anonymous users
  answers       Json // Store all quiz answers
  topIndustries Json // Calculated top industry matches
  completedAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

