  userId      String
  type        String // "job", "feedback", "certificate", "photo", "note", "milestone"
  title       String
  description String?  @db.Text
  url         String? // URL for stored files (Supabase Storage)
  metadata    Json? // Additional structured data
  isPrivate   Boolean  @default(true) // MVP: always private, future: sharing support
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

// OpportunityAlertPreference - User preferences for job/course alerts
model OpportunityAlertPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  enabled     Boolean  @default(true)
  radiusKm    Int      @default(10)
  categories  String[] // Job category slugs
  roles       String[] // Role slugs/names of interest
  notifyEmail Boolean  @default(false)
  notifyPush  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([enabled])
