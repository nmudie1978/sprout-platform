// OpportunityAlertEvent - Individual alert events for a user
model OpportunityAlertEvent {
  id        String    @id @default(cuid())
  userId    String
  type      String // "job_match", "course_match"
  entityId  String // jobId or courseId
  title     String
  reason    String // Why it matched (2-3 bullet reasons)
